<Window x:Class="AudioText.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="视频嚼真机 V1.1 - 听完再验" Height="880" Width="1320"
        MinHeight="800" MinWidth="1120"
        Icon="Assets/app-icon.ico"
        WindowStartupLocation="CenterScreen">
    <!--
        主窗口基础布局。
        Main window base layout.
        最近修改时间：2026-06-25；修改人：GG。
    -->
    <Grid Background="White" ClipToBounds="True">
        <!--
            右上角透明背景图，仅作为视觉水印，不参与鼠标命中测试。
            Top-right transparent background image; it is visual-only and does not intercept input.
            最近修改时间：2026-06-24；修改人：GG。
        -->
        <Image Source="Assets/top-right-background.png"
               Width="360"
               Margin="0,4,12,0"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Stretch="Uniform"
               Opacity="0.16"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="HighQuality" />

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="24" FontWeight="SemiBold" Text="视频嚼真机 V1.1" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#555555"
                       Text="把视频先听明白，再顺手验个真假。" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#777777"
                       FontStyle="Italic">
                <Run Text="designed by " />
                <Hyperlink NavigateUri="https://github.com/foddcus"
                           RequestNavigate="OnExternalLinkRequestNavigate">
                    <Run Text="foddcus 快怿" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UrlTextBox"
                     Grid.Column="0"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Text="https://example.com/audio.mp3" />

            <Button x:Name="CreateTaskButton"
                    Grid.Column="1"
                    Width="120"
                    Margin="10,0,0,0"
                    Content="创建任务"
                    Click="OnCreateTaskClick" />

            <Button Grid.Column="2"
                    Width="140"
                    Margin="10,0,0,0"
                    Content="系统声音监听"
                    Click="OnCaptureClick" />

            <Button Grid.Column="3"
                    Width="120"
                    Margin="10,0,0,0"
                    Content="显示目录"
                    Click="OnShowDirectoriesClick" />
        </Grid>

        <Border x:Name="VideoInfoCard"
                Grid.Row="2"
                Margin="0,0,0,14"
                Padding="12,10"
                Background="#F7F9FC"
                BorderBrush="#D5DCE8"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel>
                <DockPanel Margin="0,0,0,6">
                    <TextBlock Margin="0,0,18,0"
                               FontWeight="SemiBold"
                               Text="当前视频" />
                    <TextBlock Foreground="#666666"
                               Text="标题：" />
                    <TextBlock x:Name="VideoTitleTextBlock"
                               MaxWidth="820"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="未知" />
                </DockPanel>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Foreground="#666666"
                               Text="网站：" />
                    <TextBlock x:Name="VideoWebsiteTextBlock"
                               MinWidth="120"
                               MaxWidth="190"
                               Margin="0,0,18,0"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="未知" />
                    <TextBlock Foreground="#666666"
                               Text="发布人：" />
                    <TextBlock x:Name="VideoPublisherTextBlock"
                               MinWidth="150"
                               MaxWidth="260"
                               Margin="0,0,18,0"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="未知" />
                    <TextBlock Foreground="#666666"
                               Text="浏览量：" />
                    <TextBlock x:Name="VideoViewCountTextBlock"
                               MinWidth="100"
                               MaxWidth="160"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="未知" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar x:Name="DownloadProgressBar"
                         Grid.Column="0"
                         Height="16"
                         Minimum="0"
                         Maximum="100"
                         Value="0" />

            <TextBlock x:Name="DownloadProgressTextBlock"
                       Grid.Column="1"
                       Width="170"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Foreground="#444444"
                       Text="等待下载" />
        </Grid>

        <Border Grid.Row="4"
                Margin="0,0,0,14"
                Padding="12,10"
                Background="#F8FAFC"
                BorderBrush="#D5DCE8"
                BorderThickness="1"
                CornerRadius="8">
            <!--
                主界面仅显示 AI 设置摘要，具体 API、模型和搜索端点移入设置窗口。
                Main window shows only the AI settings summary; API, model and search endpoint fields live in the settings window.
                最近修改时间：2026-06-24；修改人：GG。
            -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="AI 设置" />

                <TextBlock x:Name="AiSettingsSummaryTextBlock"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#44546A"
                           TextWrapping="Wrap"
                           Text="尚未读取 AI 设置。" />

                <Button x:Name="SettingsButton"
                        Grid.Column="2"
                        Width="96"
                        Height="30"
                        Margin="12,0,0,0"
                        Content="设置"
                        ToolTip="打开 AI 设置页面，统一设置模型、API 地址、API Key 和 SearXNG。"
                        Click="OnOpenSettingsClick" />

                <Button x:Name="EvaluateTranscriptButton"
                        Grid.Column="3"
                        Width="130"
                        Height="30"
                        Margin="10,0,0,0"
                        Content="重新AI核查"
                        ToolTip="转写完成后会自动执行 AI 联网核查；本按钮用于失败后或修改设置后重新核查。"
                        Click="OnEvaluateTranscriptClick" />
            </Grid>
        </Border>

        <!--
            主工作区只显示内容栏、AI 评语栏、盖章和雷达图列；系统消息日志移动到下方折叠消息栏。
            Main work area shows content, AI comments, and stamp/radar columns; system logs move into the collapsed message bar below.
            最近修改时间：2026-06-25；修改人：GG。
        -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Text="内容栏（断句/纠错稿）" />

            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Margin="12,0,0,6"
                       FontWeight="SemiBold"
                       Text="AI评语栏" />

            <TextBlock Grid.Row="0"
                       Grid.Column="2"
                       Margin="12,0,0,6"
                       FontWeight="SemiBold"
                       Text="盖章和雷达图" />

            <TextBox x:Name="TranscriptPreviewTextBox"
                     Grid.Row="1"
                     Grid.Column="0"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     FontSize="15"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />

            <RichTextBox x:Name="AiEvaluationRichTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="12,0,0,0"
                         IsReadOnly="True"
                         IsDocumentEnabled="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         BorderBrush="#D5DCE8"
                         BorderThickness="1"
                         Padding="8">
                <FlowDocument PagePadding="0" FontSize="15" LineHeight="22.5">
                    <Paragraph>尚未进行 AI 联网核查；转写完成后将自动执行。</Paragraph>
                </FlowDocument>
            </RichTextBox>

            <Grid Grid.Row="1"
                  Grid.Column="2"
                  Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="340" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D5DCE8"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Canvas x:Name="AiEvaluationRadarCanvas"
                                Width="206"
                                Height="198"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False" />

                        <Border x:Name="AiEvaluationStampBorder"
                                Width="130"
                                Height="86"
                                Margin="0,10,0,0"
                                Padding="8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                BorderBrush="#94A3B8"
                                BorderThickness="2"
                                CornerRadius="8"
                                Background="#CCFFFFFF"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="-8" />
                            </Border.RenderTransform>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="盖章评级"
                                           FontSize="12"
                                           TextAlignment="Center"
                                           Foreground="#64748B" />
                                <TextBlock x:Name="AiEvaluationStampTextBlock"
                                           Margin="0,4,0,0"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Text="待评级" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="AiEvaluationScoreSummaryTextBlock"
                           Grid.Row="1"
                           Margin="0,8,0,6"
                           Foreground="#44546A"
                           TextWrapping="Wrap"
                           Text="等待评分生成雷达图和盖章评级。" />
            </Grid>
        </Grid>

        <!--
            系统消息日志默认折叠，避免占用左侧主阅读区域；需要排查时点开消息栏查看。
            System message logs are collapsed by default to keep the main reading area focused; expand the message bar when debugging.
            最近修改时间：2026-06-25；修改人：GG。
        -->
        <Expander x:Name="SystemMessageExpander"
                  Grid.Row="6"
                  Margin="0,12,0,0"
                  Header="消息栏（点开查看系统消息日志）"
                  IsExpanded="False"
                  FontWeight="SemiBold">
            <Border Margin="0,8,0,0"
                    Padding="0"
                    Background="#F8FAFC"
                    BorderBrush="#D5DCE8"
                    BorderThickness="1"
                    CornerRadius="8">
                <TextBox x:Name="OutputTextBox"
                         Height="140"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         FontSize="12"
                         FontWeight="Normal"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Border>
        </Expander>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="7"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"
                   Foreground="#444444" />
    </Grid>
    </Grid>
</Window>
