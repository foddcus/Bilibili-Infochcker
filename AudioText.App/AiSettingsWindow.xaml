<Window x:Class="AudioText.App.AiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 设置"
        Height="650"
        Width="560"
        MinHeight="620"
        MinWidth="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <!--
        AI/API 独立设置窗口。
        Dedicated AI/API settings window.
        最近修改时间：2026-06-25；修改人：GG。
    -->
    <Grid Background="White" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="22"
                       FontWeight="SemiBold"
                       Text="AI 验证设置" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#5F6B7A"
                       TextWrapping="Wrap"
                       Text="这里统一设置 AI 模型、API 地址、DeepSeek Key、Bocha Web Search Key、查验力度、可选 SearXNG 搜索端点和参考源屏蔽项；当前私有目录已恢复内置默认 Key，保存后对本次运行后续任务生效。" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="16"
                Background="#F8FAFC"
                BorderBrush="#D5DCE8"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="132" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,3,12,0"
                           VerticalAlignment="Top"
                           Text="API 地址" />
                <TextBox x:Name="DeepSeekBaseUrlTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Height="32"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="AI 模型" />
                <ComboBox x:Name="DeepSeekModelComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Height="32"
                          Margin="0,12,0,0"
                          IsEditable="True"
                          VerticalContentAlignment="Center"
                          ToolTip="可选择内置模型，也可手动输入 OpenAI 兼容模型名。" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="查验力度" />
                <ComboBox x:Name="VerificationIntensityComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Height="32"
                          Margin="0,12,0,0"
                          VerticalContentAlignment="Center"
                          ToolTip="普通：核心观点；细节：主要观点；苛刻：全部观点，不主动限制搜索量。" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="DeepSeek Key" />
                <PasswordBox x:Name="DeepSeekApiKeyPasswordBox"
                             Grid.Row="3"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,12,0,0"
                             VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="Bocha Search Key" />
                <PasswordBox x:Name="BochaWebSearchApiKeyPasswordBox"
                             Grid.Row="4"
                             Grid.Column="1"
                             Height="32"
                             Margin="0,12,0,0"
                             VerticalContentAlignment="Center"
                             ToolTip="Bocha Web Search API Key；留空时跳过 Bocha，直接使用原有搜索降级链路。" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="SearXNG" />
                <TextBox x:Name="SearxngEndpointTextBox"
                         Grid.Row="5"
                         Grid.Column="1"
                         Height="32"
                         Margin="0,12,0,0"
                         VerticalContentAlignment="Center"
                         ToolTip="可选。填写自建或可用 SearXNG 根地址；留空时使用公开搜索降级链路。" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,17,12,0"
                           VerticalAlignment="Top"
                           Text="屏蔽源" />
                <WrapPanel Grid.Row="6"
                           Grid.Column="1"
                           Margin="0,12,0,0">
                    <CheckBox x:Name="BlockKuaishouCheckBox"
                              MinWidth="72"
                              Margin="0,0,12,8"
                              Content="快手" />
                    <CheckBox x:Name="BlockDouyinCheckBox"
                              MinWidth="72"
                              Margin="0,0,12,8"
                              Content="抖音" />
                    <CheckBox x:Name="BlockXiaohongshuCheckBox"
                              MinWidth="84"
                              Margin="0,0,12,8"
                              Content="小红书" />
                    <CheckBox x:Name="BlockBilibiliCheckBox"
                              MinWidth="72"
                              Margin="0,0,12,8"
                              Content="b站" />
                    <CheckBox x:Name="BlockZhihuCheckBox"
                              MinWidth="72"
                              Margin="0,0,12,8"
                              Content="知乎" />
                </WrapPanel>

                <TextBlock Grid.Row="7"
                           Grid.Column="1"
                           Margin="0,12,0,0"
                           Foreground="#64748B"
                           TextWrapping="Wrap"
                           Text="注意：DeepSeek Key 用于断句和评分；Bocha Key 仅用于联网搜索且可留空。勾选的屏蔽源不会作为 AI 核查证据。Key 不会写入任务日志或 AI 报告。" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="108"
                    Height="32"
                    Content="恢复默认"
                    Click="OnResetClick" />

            <Button Grid.Column="2"
                    Width="92"
                    Height="32"
                    Margin="0,0,10,0"
                    Content="取消"
                    IsCancel="True" />

            <Button Grid.Column="3"
                    Width="92"
                    Height="32"
                    Content="保存"
                    IsDefault="True"
                    Click="OnSaveClick" />
        </Grid>
    </Grid>
</Window>
