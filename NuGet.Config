<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    离线构建配置。
    Offline build configuration.
    最近修改时间：2026-06-23；修改人：GG。

    说明：
    当前基础框架不依赖 NuGet 包，因此清空包源可避免受限网络环境下 restore 失败。
    后续接入 NAudio、测试框架或其他 NuGet 包时，需要恢复 nuget.org 或配置本地包源。
  -->
  <packageSources>
    <clear />
  </packageSources>
</configuration>
